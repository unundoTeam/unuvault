{
  "name": "unuvault",
  "description": "Personal local-first password manager workspace for Mac local vault, browser fill, web vault, and iPhone.",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev:api": "pnpm --filter @unuvault/api dev",
    "dev:web": "pnpm --filter @unuvault/web dev",
    "secrets:provider": "tsx scripts/secrets/provider.ts",
    "smoke:packaged-extension-mac-companion": "node scripts/smoke/packaged-extension-mac-companion.mjs",
    "smoke:menu-app-extension-mac-companion": "node scripts/smoke/menu-app-extension-mac-companion.mjs",
    "smoke:menu-app-local-save-mac-companion": "node scripts/smoke/menu-app-extension-mac-companion.mjs --save-through-menu",
    "smoke:menu-app-manual-input-mac-companion": "node scripts/smoke/menu-app-extension-mac-companion.mjs --manual-input-menu",
    "smoke:menu-app-security-boundaries-mac-companion": "node scripts/smoke/menu-app-security-boundaries-mac-companion.mjs",
    "smoke:web-save-to-mac-companion": "node scripts/smoke/web-save-to-mac-companion.mjs",
    "smoke:local-credential-bridge-server": "tsx scripts/smoke/local-credential-bridge-server.ts",
    "test": "bash scripts/testing/test-runner.sh",
    "test:ios:ui-host": "bash scripts/testing/run-ios-ui-host.sh",
    "test:macos": "bash scripts/testing/run-macos.sh",
    "test:macos:security-preflight": "bash scripts/testing/run-mac-security-preflight.sh",
    "test:macos:install-readiness": "bash scripts/testing/run-mac-install-readiness.sh",
    "test:macos:distribution-readiness": "bash scripts/testing/run-mac-distribution-readiness.sh",
    "test:macos:login-item-receipt": "bash scripts/testing/run-mac-login-item-receipt.sh",
    "test:macos:local-vault-receipt": "bash scripts/testing/run-mac-local-vault-receipt.sh",
    "test:macos:local-user-presence": "bash scripts/testing/run-mac-local-user-presence.sh",
    "test:macos:touch-id-prompt-receipt": "bash scripts/testing/run-mac-touch-id-prompt-receipt.sh",
    "test:macos:account-import-receipt": "bash scripts/testing/run-mac-account-import-receipt.sh",
    "test:macos:pairing-boundary": "swift test --package-path apps/macos/App --filter Pairing",
    "test:macos:recovery-boundary": "swift test --package-path apps/macos/App --filter RecoveryBoundaryTests",
    "test:pairing-boundary": "bash scripts/testing/run-pairing-boundary.sh",
    "test:pairing-lan-smoke": "bash scripts/testing/run-pairing-lan-smoke.sh",
    "test:pairing-physical-preflight": "bash scripts/testing/run-pairing-physical-receipt.sh --preflight",
    "test:pairing-physical-receipt": "bash scripts/testing/run-pairing-physical-receipt.sh",
    "lint": "bash scripts/testing/lint-runner.sh"
  },
  "devDependencies": {
    "@fastify/cors": "^11.2.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.0",
    "fastify": "^5.8.2",
    "jsdom": "^28.1.0",
    "next": "^16.1.6",
    "pnpm": "^10.32.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
